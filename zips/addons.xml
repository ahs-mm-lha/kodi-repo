<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.cricket.live"
       name="Cricket Live"
       version="2.0.0"
       provider-name="MyATV">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Live Cricket, News, Documentaries &amp; More</summary>
        <description lang="en">28 verified live channels: Cricket (Willow, Cricket Gold, DD Sports), News (Al Jazeera, ABC, CBS, France 24, DW), Documentaries (BBC Earth, NatGeo, WildEarth), Movies, Kids (PBS Kids, Nickelodeon) and Sports. Built for ICC T20 World Cup 2026.</description>
        <language>en</language>
        <platform>all</platform>
        <license>GPL-2.0</license>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

<addon id="repository.myatv"
       name="MyATV Repository"
       version="1.0.0"
       provider-name="MyATV">
    <extension point="xbmc.addon.repository" name="MyATV Repository">
        <dir>
            <info compressed="false">https://myatv-iptv.github.io/kodi-repo/zips/addons.xml</info>
            <checksum>https://myatv-iptv.github.io/kodi-repo/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://myatv-iptv.github.io/kodi-repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">MyATV IPTV Repository</summary>
        <description lang="en">Install and auto-update MyATV addons including Cricket Live with 28+ verified live TV channels covering Cricket, News, Documentaries, Movies, Kids and more.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

</addons>
